name: Self Hosted Runner Demo

on:
  workflow_dispatch:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: [self-hosted, Linux, X64]

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Print runner name
        run: echo "Runner name is $RUNNER_NAME"

      - name: System info
        run: uname -a

      - name: Test step
        run: echo "Running on SelfHostedLinuxRunner"
